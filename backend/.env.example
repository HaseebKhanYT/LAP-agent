# ── LAP backend configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. The API BOOTS without these set; they are only
# required once you start an actual learning run (LLM inference).

# Nebius Token Factory (OpenAI-compatible). Required for learning runs.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
NEBIUS_TEMPERATURE=0.0

# Redis — used for the LangGraph checkpointer, response caching, and the run
# event bus. The app degrades gracefully (in-memory fallback) if unavailable.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# API
ENVIRONMENT=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (the Next.js console).
CORS_ORIGINS=http://localhost:3000

# Default crawl budget for a learning run.
RUN_MAX_STEPS=200
